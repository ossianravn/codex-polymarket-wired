{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "packages/**/*.ts",
    "servers/**/*.ts",
    "services/**/*.ts",
    "tests/**/*.ts"
  ]
}
