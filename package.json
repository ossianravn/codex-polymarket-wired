{
  "name": "codex-polymarket",
  "private": true,
  "version": "0.1.0",
  "description": "skill-first codex plugin scaffold for polymarket opportunity classification, research, and guarded trading",
  "type": "module",
  "workspaces": [
    "packages/*",
    "servers/*",
    "services/*"
  ],
  "scripts": {
    "dev:mcp": "tsx ./servers/polymarket-mcp/src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test ./tests/**/*.test.ts",
    "setup:python-helper": "python3 -m pip install -r ./servers/polymarket-mcp/helpers/requirements.txt",
    "smoke:mcp": "tsx ./scripts/smoke-mcp.ts",
    "smoke:autotrader-mcp": "node ./scripts/autotrader-mcp-smoke.mjs",
    "dev:watcher": "tsx ./services/watcher-daemon/src/index.ts",
    "watcher:once": "tsx ./services/watcher-daemon/src/index.ts --once",
    "dev:executor": "tsx ./services/executor-daemon/src/index.ts",
    "executor:once": "tsx ./services/executor-daemon/src/index.ts --once",
    "state:summary": "tsx ./scripts/state-summary.ts",
    "state:maintenance": "tsx ./scripts/state-maintenance.ts",
    "state:queue": "tsx ./scripts/execution-queue.ts",
    "autotrader:heartbeat": "node ./scripts/autotrader-heartbeat.mjs",
    "autotrader:automation": "node ./scripts/autotrader-automation.mjs",
    "autotrader:automation:dry-run": "node ./scripts/autotrader-automation.mjs --dry-run",
    "autotrader:daemon": "tsx ./scripts/autotrader-daemon.ts",
    "autotrader:daemon:once": "tsx ./scripts/autotrader-daemon.ts --once",
    "autotrader:status": "node ./scripts/autotrader-status.mjs",
    "autotrader:status:json": "node ./scripts/autotrader-status.mjs --json",
    "autotrader:due-status": "node ./scripts/autotrader-status.mjs --due-status",
    "autotrader:due-status:json": "node ./scripts/autotrader-status.mjs --due-status --json",
    "autotrader:paper-report": "tsx ./scripts/autotrader-paper-report.ts",
    "autotrader:paper-report:json": "tsx ./scripts/autotrader-paper-report.ts --json",
    "autotrader:research-worker": "tsx ./scripts/autotrader-research-worker.ts",
    "autotrader:research-worker:json": "tsx ./scripts/autotrader-research-worker.ts --json",
    "autotrader:research-provider": "tsx ./scripts/autotrader-research-provider.ts",
    "autotrader:research-template": "tsx ./scripts/autotrader-research-worker.ts --template --json",
    "autotrader:session": "tsx ./scripts/autotrader-session.ts",
    "autotrader:session:json": "tsx ./scripts/autotrader-session.ts --json",
    "universe:once": "tsx ./scripts/universe-discovery.ts",
    "forecast:write": "tsx ./scripts/forecast-writer.ts",
    "autotrader:once": "tsx ./scripts/autotrader-iteration.ts",
    "autotrader:simulate": "tsx ./scripts/autotrader-simulation.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "ethers": "^5.8.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
